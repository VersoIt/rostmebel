# Server
PORT=8080
ENV=development # development|production

# Database
DATABASE_URL=postgres://user:password@localhost:5432/rostmebel?sslmode=disable

# Redis
REDIS_URL=localhost:6379
REDIS_PASSWORD=

# Gemini AI
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_FALLBACK_MODELS=gemini-2.5-flash-lite

# JWT
JWT_SECRET=your-256-bit-secret
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=720h

# Admin
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me-in-production
ORDER_LIMIT_ENABLED=true

# Outbound proxy for Gemini/Telegram. Leave host/port empty to disable.
OUTBOUND_PROXY_SCHEME=http
OUTBOUND_PROXY_HOST=
OUTBOUND_PROXY_PORT=
OUTBOUND_PROXY_USERNAME=
OUTBOUND_PROXY_PASSWORD=

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:80
